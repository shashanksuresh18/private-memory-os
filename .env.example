# Sovereign Citadel — environment template.
# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# Cloud keys are only needed for S1/S2 cloud features; S3 is always local-only.

# --- Cloud provider (S1 public + S2 DLP-redacted only) ---
NEBIUS_API_KEY=
NEBIUS_BASE_URL=

# --- Gmail connector (optional) ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_ACCOUNTS_JSON=

# --- Calendar connector (optional) ---
CALENDAR_CLIENT_ID=
CALENDAR_CLIENT_SECRET=
CALENDAR_REFRESH_TOKEN=

# --- Local retrieval / models (no cloud) ---
RETRIEVAL_EMBEDDER=ollama
OLLAMA_URL=http://127.0.0.1:11434
